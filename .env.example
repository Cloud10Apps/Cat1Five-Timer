# ─── Database ───────────────────────────────────────────────────────────────
# PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Auth ────────────────────────────────────────────────────────────────────
# Secret used to sign JWT tokens — use a long random string (required)
SESSION_SECRET=change-me-to-a-long-random-secret

# ─── Server ──────────────────────────────────────────────────────────────────
# Port the API server listens on (default: 3000)
PORT=3000

# Node environment: "production" | "development" (default: development)
NODE_ENV=production

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Leave empty to allow all origins (not recommended for production).
ALLOWED_ORIGINS=https://your-app.example.com

# ─── Frontend ────────────────────────────────────────────────────────────────
# Base path for the Vite dev server (default: /)
BASE_PATH=/

# ─── Bootstrap (first-time setup) ───────────────────────────────────────────
# These are only used once, on first startup when the database is empty.
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change-me-admin-password
BOOTSTRAP_USER_EMAIL=inspector@example.com
BOOTSTRAP_USER_PASSWORD=change-me-user-password
